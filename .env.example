# ============================================================
# MBC Backend — Variables de entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# JWT — usa una clave larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET=cambia-esta-clave-por-una-aleatoria-muy-larga-y-segura

# Usuarios del sistema
# Genera los hashes con: python generate_passwords.py
ADMIN_USER=admin
ADMIN_HASH=admin123

VIEWER_USER=visualizador
VIEWER_HASH=viewer123
